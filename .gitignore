**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
/build/

# FVM (Flutter Version Management)
.fvm/

# Test coverage
coverage/

